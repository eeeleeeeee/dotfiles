{{- if eq .chezmoi.os "windows" -}}
$ErrorActionPreference = "Stop"

Write-Host "=== Fonts Setup ===" -ForegroundColor Cyan

# Scoop must be installed before running this script
if (-not (Get-Command scoop -ErrorAction SilentlyContinue)) {
    Write-Host "[scoop] not found. Please install Scoop first: https://scoop.sh" -ForegroundColor Red
    exit 1
}

# Reset scoop and all buckets to clean state to prevent "Uncommitted changes" errors
$scoopInstall = "$env:USERPROFILE\scoop\apps\scoop\current"
if (Test-Path "$scoopInstall\.git") {
    git -C $scoopInstall reset --hard HEAD --quiet 2>$null
}
Get-ChildItem "$env:USERPROFILE\scoop\buckets" -Directory -ErrorAction SilentlyContinue | ForEach-Object {
    git -C $_.FullName reset --hard HEAD --quiet 2>$null
}

function Remove-FontFiles {
    param([string]$Pattern)
    $fontsDir = "$env:LOCALAPPDATA\Microsoft\Windows\Fonts"
    Get-ChildItem $fontsDir -Filter $Pattern -ErrorAction SilentlyContinue | ForEach-Object {
        try {
            Remove-Item $_.FullName -Force -ErrorAction Stop
        } catch {
            Rename-Item $_.FullName -NewName ($_.Name + ".bak") -ErrorAction SilentlyContinue
        }
    }
}

function Install-ScoopPackage {
    param([string]$Package, [string]$FontPattern)
    if (scoop list $Package 2>$null | Select-String $Package) {
        Write-Host "[$Package] already installed, skipping." -ForegroundColor Gray
    } else {
        Write-Host "[$Package] Installing..." -ForegroundColor Yellow
        if ($FontPattern) { Remove-FontFiles $FontPattern }
        scoop install $Package
    }
}

$buckets = scoop bucket list
if ($buckets -notcontains "nerd-fonts") {
    scoop bucket add nerd-fonts
}

# ── CaskaydiaCove Nerd Font Mono ──────────────────────────────────────────
Install-ScoopPackage "cascadiacode-nf-mono" "CaskaydiaCoveNerdFontMono-*.ttf"

# ── JetBrains Mono ────────────────────────────────────────────────────────
Install-ScoopPackage "jetbrains-mono" "JetBrainsMono-*.ttf"
Install-ScoopPackage "JetBrainsMono-NF" "JetBrainsMonoNerdFont-*.ttf"
Install-ScoopPackage "JetBrainsMono-NF-Mono" "JetBrainsMonoNerdFontMono-*.ttf"

# ── Google Noto ───────────────────────────────────────────────────────────
Install-ScoopPackage "Noto-NF" "NotoSansM Nerd Font*.ttf"
Install-ScoopPackage "Noto-NF-Mono" "NotoSansMNerdFontMono-*.ttf"
Install-ScoopPackage "Noto-CJK-Mega-OTC" "Noto*.otc"

Write-Host "=== Fonts setup complete. ===" -ForegroundColor Cyan
{{- end -}}
