{{- if eq .chezmoi.os "windows" -}}
$ErrorActionPreference = "Stop"

Write-Host "=== Windows Terminal Settings Sync ===" -ForegroundColor Cyan

$settingsDir  = Join-Path $env:LOCALAPPDATA "Packages\Microsoft.WindowsTerminal_8wekyb3d8bbwe\LocalState"
$settingsPath = Join-Path $settingsDir "settings.json"

if (-not (Test-Path $settingsDir)) {
    Write-Host "[windows-terminal] not installed, skipping." -ForegroundColor Yellow
    exit 0
}

if (-not (Get-Command jq -ErrorAction SilentlyContinue)) {
    Write-Host "[jq] not found, skipping Windows Terminal sync." -ForegroundColor Yellow
    exit 0
}

$patch = @'
{
  "defaultProfile": "{574e775e-4f2a-5b96-ac1e-a2962a402336}",
  "defaultInputScope": "alphanumericHalfWidth",
  "windowingBehavior": "useExisting",
  "profiles": {
    "defaults": {
      "cursorShape": "filledBox",
      "font": {
        "face": "JetBrainsMono Nerd Font"
      },
      "intenseTextStyle": "all"
    }
  }
}
'@

if (Test-Path $settingsPath) {
    $existing = Get-Content -Raw $settingsPath
} else {
    $existing = "{}"
}

$merged = ($existing, $patch) | jq -s '.[0] * .[1]'
if ($LASTEXITCODE -ne 0) {
    Write-Host "[jq] merge failed." -ForegroundColor Red
    exit 1
}

$utf8NoBom = New-Object System.Text.UTF8Encoding $false
[System.IO.File]::WriteAllText($settingsPath, ($merged -join "`n"), $utf8NoBom)

Write-Host "Windows Terminal settings merged." -ForegroundColor Green
{{- end -}}
