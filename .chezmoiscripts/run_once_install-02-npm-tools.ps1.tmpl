{{- if eq .chezmoi.os "windows" -}}
$ErrorActionPreference = "Stop"

Write-Host "=== npm Global Tools Setup ===" -ForegroundColor Cyan

# npm is installed by run_once_install-dev-tools, which must run first
if (-not (Get-Command npm -ErrorAction SilentlyContinue)) {
    Write-Host "[npm] not found, skipping all npm installs." -ForegroundColor Yellow
    exit 0
}

function Install-NpmPackage {
    param([string]$Command, [string]$Package)
    if (Get-Command $Command -ErrorAction SilentlyContinue) {
        Write-Host "[$Command] already installed, skipping." -ForegroundColor Gray
    } else {
        Write-Host "[$Command] Installing $Package..." -ForegroundColor Yellow
        npm install -g $Package
    }
}

# ── Claude Code ───────────────────────────────────────────────────────────
Install-NpmPackage "claude" "@anthropic-ai/claude-code"

# ── codegraph (semantic code graph MCP) ──────────────────────────────────
Install-NpmPackage "codegraph" "@colbymchenry/codegraph"

Write-Host "=== npm global tools setup complete. ===" -ForegroundColor Cyan
{{- end -}}
